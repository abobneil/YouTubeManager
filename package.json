{
  "name": "yt-manager-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "npm run validate:runtime && next start -H 0.0.0.0 -p 3000",
    "lint": "eslint .",
    "worker": "npm run validate:runtime && tsx src/worker/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:runtime": "tsx scripts/validate-runtime-config.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "next": "16.1.6",
    "node-cron": "^4.2.1",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.16.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
